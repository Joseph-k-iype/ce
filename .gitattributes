# Set default line ending to LF for cross-platform compatibility
* text=auto eol=lf

# Docker files should always use LF (Linux line endings)
*.sh text eol=lf
Dockerfile text eol=lf
docker-compose.yml text eol=lf
.dockerignore text eol=lf

# Windows batch files should use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
