# UAT environment overrides
ENVIRONMENT=uat

# FalkorDB credentials (override base .env per environment)
FALKORDB_USERNAME=
FALKORDB_PASSWORD=
API_DEBUG=false
API_RELOAD=false
LOG_LEVEL=INFO
# Tighten CORS in UAT — update with actual UAT frontend URL
CORS_ORIGINS=["https://uat.compliance.internal"]
ENABLE_LOCAL_FALLBACK=false
ENABLE_LDAP=true
OPERATIONAL_DB_PATH=data/operational_uat.db
