# Compliance Engine Environment Config
# Place this at the root of the backend directory

# Authentication & JWT
JWT_SECRET_KEY=yoursecretkeyhere_minimum_32_characters_long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# LDAP Config
ENABLE_LDAP=True
LDAP_SERVER_URL=ldap://localhost:389
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_SEARCH_BASE=DC=example,DC=com

# AI / LLM Service Configuration
AI_TOKEN_API_URL=https://cmb-ib2b-dsp-sjdf/ib2b_tokenTranslator?_action=translate
AI_TOKEN_USERNAME=
AI_TOKEN_PASSWORD=
AI_LLM_API_URL=https://gapi-api.com/v1/api/v1/chat/completions
AI_LLM_MODEL=o3-mini
AI_USE_CASE_ID=compliance-engine
AI_TOKEN_EXPIRY_BUFFER=300

# Feature Flags
ENABLE_AI_RULE_GENERATION=True
ENABLE_AI_RULE_TESTING=True
ENABLE_AGENTIC_MODE=True
ENABLE_AUTO_REFERENCE_DATA=True
AGENT_AUDIT_RETENTION_DAYS=90
REQUIRE_APPROVAL_FOR_WRITES=True

# Headers
AI_AUTH_TOKEN_TYPE=SESSION_TOKEN
AI_AUTH_HEADER_NAME=X-HSBC-E2E-Trust-Token
AI_CORRELATION_ID_HEADER=x-correlation-id
AI_SESSION_ID_HEADER=x-usersession-id
